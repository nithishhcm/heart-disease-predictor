# ==========================================
# NeuroHeart AI - Platform Configuration
# ==========================================

# Application environment: production or development
ENVIRONMENT=development

# Database connection:
# Fallback to local SQLite (sqlite:///./medical_ai.db) if empty
# Configure with valid postgresql URL for cloud deployment (Render, AWS)
# Example: postgresql://username:password@host:5432/dbname
DATABASE_URL=sqlite:///./medical_ai.db

# Cryptographic Keys (Mandatory: replace with secure keys in production!)
SECRET_KEY=supersecretkey_for_medical_ai_app_in_production_change_this
REFRESH_SECRET_KEY=superrefreshsecretkey_for_medical_ai_app_change_this

# Token Lifespans (Minutes & Days)
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Sliding IP Rate Limiter Limits
# Defaults: Max 60 requests per 60 seconds per IP address
RATE_LIMIT_CALLS=60
RATE_LIMIT_PERIOD_SECONDS=60

# Model Paths
MODEL_PATH=models/model.pkl
SCALER_PATH=models/scaler.pkl
BACKGROUND_DATA_PATH=data/heart.csv
